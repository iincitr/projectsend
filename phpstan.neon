includes:
    - phpstan-baseline.neon

parameters:
    level: 6
    paths:
        - includes/Classes/
        - .
    excludePaths:
        - vendor/
        - node_modules/
        - upload/
        - install/
        - cache/
        - my_files/
    scanDirectories:
        - includes/
    ignoreErrors:
        # Ignore dynamic property access patterns common in ProjectSend
        - '#Access to an undefined property#'
        - '#Call to an undefined method PDO::#'